<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xixi.manjuagent.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.xixi.manjuagent.entity.User">
        <id column="id" property="id"/>
        <result column="email" property="email"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="avatar" property="avatar"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="last_login_at" property="lastLoginAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, email, password, nickname, avatar, status, created_at, updated_at, last_login_at
    </sql>

    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM users
        WHERE id = #{id}
    </select>

    <select id="findByEmail" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM users
        WHERE email = #{email}
    </select>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM users
        ORDER BY created_at DESC
    </select>

    <select id="countByEmail" resultType="int">
        SELECT COUNT(*)
        FROM users
        WHERE email = #{email}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (email, password, nickname, avatar, status, created_at, updated_at)
        VALUES (#{email}, #{password}, #{nickname}, #{avatar}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update">
        UPDATE users
        SET nickname = #{nickname},
            avatar = #{avatar},
            status = #{status},
            updated_at = #{updatedAt},
            last_login_at = #{lastLoginAt}
        WHERE id = #{id}
    </update>

    <update id="updatePassword">
        UPDATE users
        SET password = #{password},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM users WHERE id = #{id}
    </delete>

</mapper>
